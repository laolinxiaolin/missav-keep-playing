{
  "manifest_version": 3,
  "name": "Missal Keep Playing",
  "version": "1.0.0",
  "description": "Prevents videos on missal.ai from auto-pausing when the browser window loses focus",
  "permissions": ["scripting"],
  "host_permissions": ["*://missal.ai/*", "*://*.missal.ai/*", "*://missal.ws/*", "*://*.missal.ws/*"],
  "content_scripts": [
    {
      "matches": ["*://missal.ai/*", "*://*.missal.ai/*", "*://missal.ws/*", "*://*.missal.ws/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
