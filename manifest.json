{
  "manifest_version": 3,
  "name": "Missav Keep Playing",
  "version": "1.1.0",
  "description": "Prevents videos on missav.ai from auto-pausing when the browser window loses focus",
  "permissions": ["scripting"],
  "host_permissions": [
    "*://missav.ai/*",
    "*://*.missav.ai/*",
    "*://missav.ws/*",
    "*://*.missav.ws/*",
    "*://missav.com/*",
    "*://*.missav.com/*",
    "*://missav.live/*",
    "*://*.missav.live/*",
    "*://thisav.com/*",
    "*://*.thisav.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://missav.ai/*",
        "*://*.missav.ai/*",
        "*://missav.ws/*",
        "*://*.missav.ws/*",
        "*://missav.com/*",
        "*://*.missav.com/*",
        "*://missav.live/*",
        "*://*.missav.live/*",
        "*://thisav.com/*",
        "*://*.thisav.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
